# siwx-go demo hub configuration.
# Copy to ".env" and adjust. Real environment variables override these.
# The hub reads this file at startup (see examples/hub/config.go).

# ---- Network / addressing ----
# Hostname only (no port). Combined with SIWX_PORT into the SIWS/SIWE domain
# authority that wallets and the verifier must agree on, e.g. "localhost:8081".
SIWX_DOMAIN=localhost

# Port the hub listens on and advertises in the domain.
SIWX_PORT=8081

# Full listen address. Defaults to ":<SIWX_PORT>". Override to bind a specific
# interface, e.g. "127.0.0.1:8081".
# SIWX_ADDR=:8081

# Public URL of the JWKS document used to validate issued tokens.
# SIWX_JWKS_URL=http://localhost:8081/.well-known/jwks.json

# ---- Token issuer (JWT claims) ----
# "iss" claim on issued tokens.
SIWX_ISSUER_URL=https://accounts.example.local

# "aud" claim on issued tokens.
SIWX_AUDIENCE=siwx-go-demo

# ---- Sign-in message (surfaced to the browser via GET /config) ----
# Human-readable statement shown in the wallet sign-in prompt.
SIWX_STATEMENT=Sign in to siwx-go demo

# Solana cluster placed in the SIWS "Chain ID" field (e.g. mainnet, devnet).
SIWX_SOLANA_CHAIN=mainnet

# Sign-in message validity window, in minutes (sets Expiration Time).
SIWX_SESSION_TTL_MIN=10
